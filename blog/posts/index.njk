---
permalink: /blog/index.html
eleventyExcludeFromCollections: true
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Blog | TopMark — Tips, Guides & Academic Resources</title>
  <meta name="description" content="Guides and tips on hiring academic experts, essay writing, nursing coursework, cybersecurity assignments, and more from TopMark." />
  <meta name="robots" content="index, follow" />
  <meta name="theme-color" content="#1dbf73" />
  <link rel="canonical" href="https://topmark.pro/blog/" />
  <link rel="icon" type="image/png" href="/images/logow.png" />
  <link rel="stylesheet" href="/blog/style.css" />
</head>
<body>
  <header class="blog-header">
    <a href="/" class="blog-logo">TopMark</a>
    <nav>
      <a href="/blog">Blog</a>
      <a href="/gigs">Browse Experts</a>
    </nav>
  </header>

  <main class="blog-index">
    <h1>TopMark Blog</h1>
    <p class="blog-subtitle">Guides and tips for students working with academic experts.</p>

    <ul class="post-list">
      {% for post in collections.posts %}
      <li class="post-card">
        <a href="{{ post.url }}">
          <h2>{{ post.data.title }}</h2>
          <p class="blog-meta">{{ post.data.date | readableDate }}</p>
          <p>{{ post.data.description }}</p>
        </a>
      </li>
      {% endfor %}
    </ul>
  </main>

  <footer class="blog-footer">
    <p>&copy; {{ currentYear }} TopMark. All rights reserved.</p>
  </footer>
</body>
</html>